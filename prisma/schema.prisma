generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  OWNER
  EMPLOYEE
}

enum ProductStatus {
  OK
  NEAR_EXPIRY
  EXPIRED
}

enum WasteReason {
  EXPIRED
  DAMAGED
  SPOILED
  OTHER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Onboarding
  onboardingCompleted Boolean @default(false)

  // Email verification
  emailVerified           DateTime?
  verificationToken       String?   @unique
  verificationTokenExpiry DateTime?

  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model Business {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  
  // Profile & Branding
  logoUrl       String?
  brandColor    String?
  address       String?
  phone         String?
  email         String?
  socials       Json?     // { instagram, facebook, tiktok, website }

  // Operations
  openingHours  Json?     // { monday: { open: "09:00", close: "18:00", closed: false }, ... }
  
  // Configuration & Intelligence
  settings      Json?     // { stockAlerts: true, autoDeduct: true, currency: "EUR", ... }

  users         User[]
  locations Location[]
  recipes   Recipe[]
  orders    Order[]
  predictionSnapshots PredictionSnapshot[]
  predictionAccuracy  PredictionAccuracy[]

  subscriptionTier     SubscriptionTier     @default(FREE)
  subscriptionStatus   SubscriptionStatus   @default(ACTIVE)
  subscriptionEndDate  DateTime?

  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  trialEndsAt          DateTime?

  // SumUp integration
  sumupAccessToken    String?
  sumupRefreshToken   String?
  sumupMerchantCode   String?
  sumupTokenExpiresAt DateTime?
  sumupConnectedAt    DateTime?

  sumupTransactions SumUpTransaction[]
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  CANCELED
  PAST_DUE
}

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String?
  latitude  Float?
  longitude Float?
  radius    Int      @default(500) // in meters
  type      String?  // MARKET, EVENT, SPOT, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  products   Product[]
  dailySales DailySales[]
  orders     Order[]
  predictionSnapshots PredictionSnapshot[]
  predictionAccuracy  PredictionAccuracy[]

  @@index([businessId])
}

model Product {
  id           String        @id @default(cuid())
  name         String
  category     String?
  quantity     Float
  unit         String        // e.g., kg, liters, units
  purchaseDate DateTime?
  expiryDate   DateTime
  costPerUnit  Float?
  status       ProductStatus @default(OK)
  imageUrl     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  wasteEvents WasteEvent[]
  recipeIngredients RecipeIngredient[]
  stockHistory StockHistory[]

  @@index([locationId])
  @@index([status])
  @@index([expiryDate])
}

model WasteEvent {
  id        String      @id @default(cuid())
  quantity  Float
  reason    WasteReason
  date      DateTime    @default(now())
  
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

model Recipe {
  id          String   @id @default(cuid())
  name        String
  description String?
  sellingPrice Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  ingredients RecipeIngredient[]
  dailySales  DailySales[]
  orderItems  OrderItem[]
  predictionSnapshots PredictionSnapshot[]
  predictionAccuracy  PredictionAccuracy[]
  sumupTransactions   SumUpTransaction[]

  @@index([businessId])
}

model RecipeIngredient {
  id        String @id @default(cuid())
  quantity  Float
  unit      String

  recipeId  String
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([recipeId])
  @@index([productId])
}

model DailySales {
  id           String   @id @default(cuid())
  date         DateTime @default(now())
  quantity     Int
  unitPrice    Float?
  totalRevenue Float?
  
  weatherSnapshot Json? // { temp: 20, condition: "Sunny", rain: false }
  
  recipeId     String
  recipe       Recipe   @relation(fields: [recipeId], references: [id])

  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])

  @@index([recipeId])
  @@index([locationId])
  @@index([date])
}

enum StockChangeType {
  MANUAL
  SALES
  WASTE
  DELIVERY
}

model StockHistory {
  id        String          @id @default(cuid())
  date      DateTime        @default(now())
  quantity  Float
  type      StockChangeType
  note      String?

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

model Order {
  id           String      @id @default(cuid())
  date         DateTime    @default(now())
  totalRevenue Float?
  
  weatherSnapshot Json?
  
  locationId   String?
  location     Location?   @relation(fields: [locationId], references: [id])
  
  businessId   String
  business     Business    @relation(fields: [businessId], references: [id])

  items        OrderItem[]

  @@index([businessId])
  @@index([locationId])
  @@index([date])
}

model OrderItem {
  id        String @id @default(cuid())
  quantity  Int
  unitPrice Float?
  subtotal  Float?
  
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  recipeId  String
  recipe    Recipe @relation(fields: [recipeId], references: [id])

  @@index([orderId])
  @@index([recipeId])
}

model PredictionSnapshot {
  id                String   @id @default(cuid())
  date              DateTime
  createdAt         DateTime @default(now())

  recipeId          String
  recipe            Recipe   @relation(fields: [recipeId], references: [id])

  locationId        String?
  location          Location? @relation(fields: [locationId], references: [id])

  businessId        String
  business          Business @relation(fields: [businessId], references: [id])

  predictedQuantity Int
  trend             String   // 'UP' | 'DOWN' | 'STABLE'

  weatherForecast   Json?
  dayOfWeek         Int
  algorithmVersion  String   @default("v1")

  @@unique([date, recipeId, businessId, locationId])
  @@index([businessId])
  @@index([recipeId])
  @@index([locationId])
  @@index([date])
}

model SumUpTransaction {
  id              String    @id @default(cuid())
  sumupId         String    @unique
  transactionCode String?
  amount          Float
  currency        String    @default("EUR")
  timestamp       DateTime
  status          String
  paymentType     String?
  productSummary  String?
  products        Json?     // [{ name, quantity, price_per_unit, total_price }]

  businessId      String
  business        Business  @relation(fields: [businessId], references: [id])

  matchedRecipeId String?
  matchedRecipe   Recipe?   @relation(fields: [matchedRecipeId], references: [id])

  createdAt       DateTime  @default(now())

  @@index([businessId])
  @@index([timestamp])
  @@index([businessId, timestamp])
}

model PredictionAccuracy {
  id                 String   @id @default(cuid())
  date               DateTime
  computedAt         DateTime @default(now())

  recipeId           String
  recipe             Recipe   @relation(fields: [recipeId], references: [id])

  locationId         String?
  location           Location? @relation(fields: [locationId], references: [id])

  businessId         String
  business           Business @relation(fields: [businessId], references: [id])

  predictedQuantity  Int
  actualQuantity     Int

  deviation          Int
  deviationPercent   Float
  accuracyPercent    Float

  errorTags          Json     // string[]

  weatherPredicted   Json?
  weatherActual      Json?
  weatherDeltaTemp   Float?

  snapshotId         String?

  @@unique([date, recipeId, businessId, locationId])
  @@index([businessId])
  @@index([recipeId])
  @@index([locationId])
  @@index([date])
}
