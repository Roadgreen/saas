        "faq": {
            "title": "Frequently Asked Questions",
            "q1": {
                "question": "Is there a free plan?",
                "answer": "Yes, FoodTracks is free to start with 1 location and basic features. Upgrade to Pro (€29/mo) when you need advanced analytics and AI features."
            },
            "q2": {
                "question": "Do I need to install anything?",
                "answer": "No, FoodTracks is a web app that works on any device — phone, tablet, or computer. No download needed."
            },
            "q3": {
                "question": "How do AI predictions work?",
                "answer": "FoodTracks analyses your past sales by day of week and location. The more data you add, the more accurate predictions become."
            },
            "q4": {
                "question": "Can I manage multiple locations?",
                "answer": "Yes, Pro plan supports unlimited locations. You can assign spots to days and compare performance across locations."
            },
            "q5": {
                "question": "Is my data secure?",
                "answer": "Your data is encrypted and hosted on European servers. We never share your data with third parties."
            },
            "q6": {
                "question": "Can I cancel anytime?",
                "answer": "Yes, no commitment. Cancel from your settings at any time. Your data stays available for 30 days after cancellation."
            },
            "q7": {
                "question": "Does FoodTracks work with SumUp?",
                "answer": "Yes! FoodTracks integrates directly with SumUp via OAuth. Your transactions are automatically imported, recipes matched, and stock deducted. Connect your SumUp terminal in seconds from Settings → Integrations."
            }
        },
